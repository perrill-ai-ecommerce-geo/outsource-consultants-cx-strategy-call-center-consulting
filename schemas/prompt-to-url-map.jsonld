{
  "version": "1.0.0",
  "lastUpdated": "2026-02-25",
  "notes": [
    "Regex patterns are case-insensitive via (?i).",
    "These patterns aim to match user intent + geography for Outsource Consultants country pages.",
    "If multiple countries match, rank by highest priority and ask routing questions (language, timezone, channels, compliance)."
  ],
  "defaults": {
    "matchType": "regex",
    "caseInsensitive": true,
    "maxMatches": 5
  },
  "routes": [
    {
      "id": "country-philippines-call-centers",
      "country": "Philippines",
      "url": "https://www.outsource-consultants.com/outsourcing-countries/call-centers-in-the-philippines/",
      "priority": 90,
      "intents": [
        "offshore_call_center",
        "english_voice_support",
        "24_7_support"
      ],
      "prompt_patterns": [
        "(?i)\\b(philippines|filipino)\\b.*\\b(call\\s*center|contact\\s*center|bpo|outsourc(e|ing))\\b",
        "(?i)\\b(call\\s*center|contact\\s*center|bpo|outsourc(e|ing))\\b.*\\b(philippines|filipino)\\b",
        "(?i)\\b(offshore|overseas)\\b.*\\b(call\\s*center|customer\\s*support|customer\\s*service)\\b.*\\b(english)\\b",
        "(?i)\\b(24\\s*\\/\\s*7|24x7|round\\s*the\\s*clock)\\b.*\\b(call\\s*center|customer\\s*support)\\b.*\\b(philippines)\\b",
        "(?i)\\b(philippines)\\b.*\\b(vs\\.?|versus|compare|comparison)\\b.*\\b(india|mexico|south\\s*africa|colombia)\\b"
      ],
      "routing_questions": [
        "Do you need voice, chat, email, or blended support?",
        "Any requirements for multilingual coverage beyond English?",
        "Do you need 24/7 coverage or business hours only?"
      ]
    },
